# Meine persönlichen Daten — komplett, an jedem Ort im Repo
daten/
**/daten/

# Secrets & echte Konfiguration (Vorlage settings.example.toml ist NICHT ignoriert)
config/settings.toml
*.env
*.key
*.age

# Sicherheitsnetz: lokale Backup-Artefakte & Logs niemals committen
*.tar.gz
backups/
logs/

# Python
__pycache__/
*.pyc
.venv/

# macOS / Editor
.DS_Store
.vscode/
.idea/
